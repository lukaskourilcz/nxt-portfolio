# PostHog product analytics + session replay (optional).
# Leave unset and the site ships with zero tracking — the snippet only loads
# when a key is present. Get a free "Project API Key" at https://posthog.com
# (free tier: 1M events + 5K recordings/month, no card required).
NEXT_PUBLIC_POSTHOG_KEY=
# Ingest host. US cloud: https://us.i.posthog.com  ·  EU cloud: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
